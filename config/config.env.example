API_TOKEN="YOUR_CLOUDFLARE_API_TOKEN"
TELEGRAM_ENABLED="yes"
BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
CHAT_ID="YOUR_TELEGRAM_CHAT_ID"
SEND_NO_CHANGE="no"
SEND_STARTUP="yes"
DAILY_STATUS_ENABLED="yes"
DAILY_STATUS_TIME="09:00"
VERIFY_DNS="yes"
LOGGING="yes"
IPV4_PROVIDER="https://api.ipify.org"
IPV6_PROVIDER="https://api64.ipify.org"
LOG_FILE="/opt/cloudflare-ddns-telegram/logs/cloudflare-ddns.log"
STATE_FILE="/opt/cloudflare-ddns-telegram/config/ip-state.json"
RECORDS_FILE="/opt/cloudflare-ddns-telegram/config/records.conf"
